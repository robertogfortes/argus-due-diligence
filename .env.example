# =============================================================================
# ARGUS — Environment Configuration
# Copy this file to .env and fill in your values before running.
# =============================================================================

# ── LLM API key ──────────────────────────────────────────────────────────────
# Required unless you use a local model (see ARGUS_LLM_MODEL=ollama/... below).
OPENAI_API_KEY=sk-proj-...

# ── Serper API key (Google Search) ───────────────────────────────────────────
# Required for LIVE source lookups. NOT needed when ARGUS_MOCK_SOURCES=true.
# Get yours at https://serper.dev — free tier available (2,500 queries/month)
SERPER_API_KEY=...

# ── Mock sources (sources mocked, result real) ───────────────────────────────
# When true, ARGUS fakes the search/scrape lookups with an offline fixture corpus
# (argus.mock_sources) but the crew + LLM still produce a genuine analysis.
# Great for a free, reproducible run — no Serper key needed.
ARGUS_MOCK_SOURCES=false

# ── Model configuration ───────────────────────────────────────────────────────
# Provider-agnostic model override (wins over OPENAI_MODEL_NAME). Examples:
#   gpt-4o-mini            (OpenAI)
#   anthropic/claude-...   (Anthropic — needs ANTHROPIC_API_KEY)
#   ollama/llama3.1        (local, free — needs ARGUS_LLM_BASE_URL below)
# ARGUS_LLM_MODEL=ollama/llama3.1
# ARGUS_MANAGER_MODEL=gpt-4o
# ARGUS_LLM_BASE_URL=http://localhost:11434   # for a local Ollama server

# OpenAI-specific fallbacks (used if ARGUS_LLM_MODEL is unset)
OPENAI_MODEL_NAME=gpt-4o-mini
MANAGER_MODEL_NAME=gpt-4o

# LLM temperature (lower = more factual, recommended for due diligence)
AGENT_TEMPERATURE=0.2

# ── Runtime settings ──────────────────────────────────────────────────────────
# Enable verbose agent logs (true/false)
ARGUS_VERBOSE=true

# Enable CrewAI memory (true/false). Needs an embeddings provider (OpenAI); it is
# disabled automatically in mock-sources mode so any LLM provider works.
ARGUS_MEMORY=true

# ── Optional: Azure OpenAI ────────────────────────────────────────────────────
# If using Azure instead of OpenAI, set these and leave OPENAI_API_KEY unset
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-01
