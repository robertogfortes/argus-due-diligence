# =============================================================================
# ARGUS — Environment Configuration
# Copy this file to .env and fill in your values before running.
# =============================================================================

# ── Required: OpenAI API key ─────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── Required: Serper API key (Google Search) ─────────────────────────────────
# Get yours at https://serper.dev — free tier available (2,500 queries/month)
SERPER_API_KEY=...

# ── Model configuration ───────────────────────────────────────────────────────
# Model for specialist agents (default: gpt-4o-mini for cost efficiency)
OPENAI_MODEL_NAME=gpt-4o-mini

# Model for the Chief Investigation Officer manager (use a stronger model)
MANAGER_MODEL_NAME=gpt-4o

# LLM temperature (lower = more factual, recommended for due diligence)
AGENT_TEMPERATURE=0.2

# ── Runtime settings ──────────────────────────────────────────────────────────
# Enable verbose agent logs (true/false)
ARGUS_VERBOSE=true

# Enable CrewAI long-term memory (true/false)
# When true, ARGUS learns patterns across investigations
ARGUS_MEMORY=true

# ── Optional: Azure OpenAI ────────────────────────────────────────────────────
# If using Azure instead of OpenAI, set these and leave OPENAI_API_KEY unset
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
# AZURE_OPENAI_API_VERSION=2024-02-01
